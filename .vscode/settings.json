{
  // ===== 项目级编辑器行为 =====
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never"
  },
  "editor.tabSize": 2,
  "editor.indentSize": "tabSize",
  "editor.detectIndentation": true,
  "editor.formatOnSave": false,
  "editor.suggest.showDeprecated": false,

  // ===== 文件 & 排除规则（项目级）=====
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.autoSave": "afterDelay",
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.git/**": true
  },

  // ===== Explorer / 文件嵌套 =====
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,

  // ===== Git（项目级）=====
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.untrackedChanges": "separate",
  "git.openRepositoryInParentFolders": "never",
  "git.ignoreLegacyWarning": true,

  // ===== 终端（项目级）=====
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontWeight": "300",
  "terminal.integrated.tabs.enabled": true,

  // ===== 测试（项目级）=====
  "testing.openTesting": "openOnTestFailure",
  "testing.automaticallyOpenTestResults": "openOnTestFailure",

  // ===== TypeScript / JavaScript（项目级）=====
  "js/ts.validate.enabled": false,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.suggest.completeFunctionCalls": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",

  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.parameterTypes.enabled": true,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": false,

  // ===== TS 性能（工作区必须）=====
  "typescript.tsserver.useSeparateDiagnostics": true,
  "js/ts.tsserver.maxMemory": 8192,
  "js/ts.tsserver.useSyntaxServer": "never",

  // ===== ESLint =====
  "eslint.enable": true,

  // ===== 框架 / 工具链（项目强相关）=====
  "emmet.includeLanguages": {
    "vue-html": "html",
    "vue": "html"
  },

  "vue.complete.casing.props": "camel",
  "volar.format.initialIndent": {
    "html": true
  },

  "rust-analyzer.linkedProjects": [
    "./Cargo.toml"
  ],

  // ===== Windsurf / Codeium（项目级）=====
  "codeium.enableSearch": true,
  "codeium.enableConfig": {
    "*": true
  },
  "codeium.searchMaxWorkspaceFileCount": 20000,
  "codeium.enableCrossFileContext": false,
  "codeium.maxWorkspaceSize": 5000,

  // ===== GitHub Copilot（项目级关闭）=====
  "github.copilot.enableAutoCompletions": false,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "typescript": false
  },

  // ===== 拼写（项目词表）=====
  "cSpell.words": [
    "ahooks",
    "androidstudio",
    "animejs",
    "Antd",
    "anticon",
    "asynced",
    "blueprintjs",
    "bytenode",
    "commitlint",
    "Completive",
    "cpts",
    "glsl",
    "gsap",
    "highp",
    "immer",
    "ipcs",
    "jsrsasign",
    "languagedetector",
    "Leafer",
    "Maximizable",
    "mcvp",
    "Minimizable",
    "mrcvp",
    "multilines",
    "nonconstructor",
    "nonoctal",
    "nullis",
    "pako",
    "Pensby",
    "Polotno",
    "preinstall",
    "qrcode",
    "rgba",
    "rsbuild",
    "Rsbuilder",
    "rsdoctor",
    "rspack",
    "rspress",
    "scripty",
    "setstate",
    "spinkit",
    "tailwindcss",
    "textnodes",
    "Tldraw",
    "tsnd",
    "tsup",
    "typecheck",
    "xyflow",
    "Zustand"
  ],

  // ===== i18n（项目路径）=====
  "i18n-ally.localesPaths": [
    "src/rd/code/browser/i18n/locales"
  ],

  // ===== 图标映射（项目资产）=====
  "material-icon-theme.files.associations": {
    "rd-builder.config.ts": "rust"
  }
}
